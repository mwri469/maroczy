# Copy this file to `.env` (already listed in .gitignore -- never committed)
# and fill in your own values. Each teammate keeps their own `.env`; nothing
# in it is shared via git. Loaded automatically on `import maroczy` (see
# maroczy/config.py). Real environment variables always take precedence over
# these if both are set.

# London Strategic Edge API key -- get one at
# https://www.londonstrategicedge.com/data#api
LSE_API_KEY=lse_live_xxxxxxxxxxxxxxxx

# Optional: override IBKR connection defaults. Useful when several people (or
# processes) share one machine/gateway and need distinct client IDs.
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1
